{
  "manifest_version": 3,
  "name": "ImmoScout €/m² Preis-Badge",
  "version": "1.0.0",
  "description": "Zeigt den Preis pro m² als Badge in ImmoScout24-Suchergebnissen an.",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png",
    "256": "icon-256.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.immobilienscout24.de/*"],
      "js": ["content-script.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
